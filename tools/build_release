# Asahi Fedora Remix (aarch64): riscv64, mingw64, msvc64, x86_64 platforms removed.
# DO_NOT_BUILD_RISCV64 import removed. Only native aarch64 builds are supported.

import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Dict, Iterable, List, NamedTuple

from impl.common import CROSVM_ROOT, Triple, verbose

USAGE = """\
Build crosvm with release (optimized) profile on Asahi Fedora Remix (aarch64).

Build for the local machine:
  $ ./tools/build_release

Build with all aarch64 features enabled:
  $ ./tools/build_release --features=all-aarch64
"""

# Exclude incompatible crates from PGO
PGO_EXCLUDE = ["crosvm_control"]


class Executable(NamedTuple):
    """Container for info about an executable generated by cargo build/test."""

    binary_path: Path
    crate_name: str
    cargo_target: str
    kind: str
    is_test: bool
    is_fresh: bool

    @property
    def name(self):
        return f"{self.crate_name}:{self.cargo_target}"


def cargo(
    cargo_command: str,
    cwd: Path,
    flags: List[str],
    env: Dict[str, str],
) -> Iterable[Executable]:
    """
    Executes a cargo command and returns the list of executables generated.

    The build log is hidden by default and only printed if the build fails.
    In VERBOSE mode the output will be streamed directly.
    """
    message_format = "json-diagnostic-rendered-ansi" if sys.stdout.isatty() else "json"
    cmd = [
        "cargo",
        cargo_command,
        f"--message-format={message_format}",
        *flags,
    ]

    if verbose():
        print("$", " ".join(cmd))

    process = subprocess.Popen(
        cmd,
        cwd=cwd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        env=env,
    )

    messages: List[str] = []
    assert process.stdout
    for line in iter(process.stdout.readline, ""):
        if not line.startswith("{"):
            if verbose():
                print(line.rstrip())
            messages.append(line.rstrip())
            continue
        json_line = json.loads(line)
        if json_line.get("message"):
            message = json_line.get("message").get("rendered")
            if verbose():
                print(message)
            messages.append(message)
        elif json_line.get("executable"):
            yield Executable(
                Path(json_line.get("executable")),
                crate_name=json_line.get("package_id", "").split(" ")[0],
                cargo_target=json_line.get("target").get("name"),
                kind=json_line.get("target").get("kind")[0],
                is_test=json_line.get("profile", {}).get("test", False),
                is_fresh=json_line.get("fresh", False),
            )

    if process.wait() != 0:
        if not verbose():
            for message in messages:
                print(message)
        sys.exit(-1)


def main():
    import argparse

    parser = argparse.ArgumentParser(usage=USAGE)
    parser.add_argument(
        "--build-target",
        "--platform",
        "-p",
        default="aarch64",
        help="Cargo triple to build. Only 'aarch64' (aarch64-unknown-linux-gnu) is supported.",
    )
    parser.add_argument(
        "--features",
        help="Cargo features to enable. Use 'all-aarch64' for the full feature set.",
        default=None,
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Output in JSON instead of human readable format.",
    )
    parser.add_argument("--strip", action="store_true", help="Strip output binaries")
    parser.add_argument(
        "--build-profile",
        help="Select compile profile, default to release.",
        default="release",
    )
    args = parser.parse_args()

    triple = Triple.from_shorthand(args.build_target)
    env = {**os.environ, **triple.get_cargo_env()}

    flags = [
        "--workspace",
        f"--profile={args.build_profile}",
    ]
    if args.features:
        flags.append(f"--features={args.features}")

    executables = list(cargo("build", CROSVM_ROOT, flags, env))

    if args.strip:
        for exe in executables:
            if not exe.is_test and exe.kind == "bin":
                subprocess.run(["strip", str(exe.binary_path)], check=True)

    if args.json:
        import dataclasses
        print(json.dumps([e._asdict() for e in executables], default=str))
    else:
        print(f"\nBuilt {len(executables)} executables for {triple}:")
        for exe in executables:
            if not exe.is_test and exe.kind == "bin":
                print(f"  {exe.binary_path}")


if __name__ == "__main__":
    main()
