#
# Installs rutabaga_gfx dependencies (gfxstream)
# for native aarch64 on Asahi Fedora Remix.
#
# REQUIRED before: cargo build --features=all-aarch64
# These libraries are not in Fedora repos and must be built from source.
# Run once, after ./tools/setup:
#
#   ./tools/deps/install_rutabaga_gfx_deps

set -ex

sudo dnf install --assumeyes \
    python3-yaml \
    meson \
    ninja-build \
    gcc-c++ \
    mesa-libgbm-devel \
    virglrenderer-devel

DEPS_DIR=$(mktemp -d)
cd "${DEPS_DIR}"

# Fedora aarch64 uses /usr/lib64, not the Debian multiarch path /usr/lib/aarch64-linux-gnu
COMMON_PREFIX=/usr
AARCH64_LIBDIR="${COMMON_PREFIX}/lib64"

# gfxstream
git clone https://github.com/google/gfxstream
cd gfxstream
git checkout 2ac507720389a84485bfcdac9ff744d92cb0260a

meson setup build --prefix="${COMMON_PREFIX}" --libdir="${AARCH64_LIBDIR}"
ninja -C build
sudo ninja -C build install
cd ..

# Cleanup
sudo rm -rf "${DEPS_DIR}"
