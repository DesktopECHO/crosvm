#
# Installs rutabaga_gfx dependencies (minigbm, gfxstream, virglrenderer)
# for native aarch64 on Asahi Fedora Remix.
#
# REQUIRED before: cargo build --features=all-aarch64
# These libraries are not in Fedora repos and must be built from source.
# Run once, after ./tools/setup:
#
#   ./tools/deps/install_rutabaga_gfx_deps

set -ex

sudo dnf install --assumeyes \
    python3-yaml \
    meson \
    ninja-build \
    gcc-c++

DEPS_DIR=$(mktemp -d)
cd "${DEPS_DIR}"

COMMON_PREFIX=/usr
AARCH64_DIR=aarch64-linux-gnu
AARCH64_LIBDIR="${COMMON_PREFIX}/lib/${AARCH64_DIR}"

# minigbm
git clone https://chromium.googlesource.com/chromiumos/platform/minigbm
cd minigbm
git checkout b1fccad660ff4034f186d68b6474e3139e2dc4db

sudo make install \
    DESTDIR="${COMMON_PREFIX}" \
    LIBDIR=/lib/"${AARCH64_DIR}" \
    INCLUDEDIR=/include \
    OUT=out
cd ..

# gfxstream
git clone https://github.com/google/gfxstream
cd gfxstream
git checkout 2ac507720389a84485bfcdac9ff744d92cb0260a

meson setup build --prefix="${COMMON_PREFIX}" --libdir="${AARCH64_LIBDIR}"
ninja -C build
sudo ninja -C build install
cd ..

# virglrenderer
git clone https://gitlab.freedesktop.org/virgl/virglrenderer.git
cd virglrenderer
git checkout 1.0.0

meson setup build --prefix="${COMMON_PREFIX}" --libdir="${AARCH64_LIBDIR}"
ninja -C build
sudo ninja -C build install
cd ..

# Cleanup
sudo rm -rf "${DEPS_DIR}"
