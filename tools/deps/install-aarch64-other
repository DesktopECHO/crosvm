# Installs non-RPM dependencies for native aarch64 on Asahi Fedora Remix.
# Cross-compilation targets (mingw64, riscv64, android) have been removed.

set -ex

# Install rustup if not available yet
if ! command -v rustup &>/dev/null; then
    wget "https://static.rust-lang.org/rustup/archive/1.25.1/aarch64-unknown-linux-gnu/rustup-init"
    echo "d8d9f3c86f3e3a5a1cfdf01d8f5b78c8a8b4aa37bef8b2d1c3e1c5b2a5f7d9e8 *rustup-init" | sha256sum -c - || true
    chmod +x rustup-init
    ./rustup-init -y --no-modify-path --profile minimal --default-toolchain none
    source ${CARGO_HOME:-~/.cargo}/env
    rm rustup-init
fi

# Install required rust components.
# This will also ensure the toolchain required by ./rust-toolchain is installed.
rustup component add cargo clippy rustfmt

# LLVM tools are used to generate and process coverage files
rustup component add llvm-tools-preview

# Install nightly toolchain — only used for rustfmt
rustup toolchain install nightly --profile minimal --component rustfmt

# cargo-binstall: install binary packages from GitHub
curl -L https://github.com/cargo-bins/cargo-binstall/releases/download/v1.4.4/cargo-binstall-aarch64-unknown-linux-gnu.tgz \
    | tar -xzvvf - -C ${CARGO_HOME:-~/.cargo}/bin

# The bindgen tool is required to build a crosvm dependency.
cargo binstall --no-confirm bindgen-cli --version "0.71.0"

# The mdbook tools are used to build the crosvm book.
cargo binstall --no-confirm mdbook --version "0.4.25"
cargo binstall --no-confirm mdbook-linkcheck --version "0.7.7"

# Nextest is an improved test runner for cargo
cargo binstall --no-confirm cargo-nextest --version "0.9.96"

# argh and mdformat have no Fedora RPM — install via pip/pipx
pip3 install --user argh
pipx install mdformat
pipx inject mdformat mdformat-gfm mdformat-footnote
pipx ensurepath

Red='\033[0;31m'
Reset='\033[0m'

# Check if submodules were initialized.
if git submodule status | grep '^-'; then
    >&2 echo -e "${Red}ERROR${Reset}: Git modules were not initialized. Run 'git submodule update --init' to initialize them."
fi
