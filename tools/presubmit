# Asahi Fedora Remix (aarch64): only the aarch64 platform is supported.
# win64, mingw64, and riscv64 platforms have been removed.

import os
import typing
from typing import Generator, List, Literal, Optional, Tuple, Union

from impl.common import (
    CROSVM_ROOT,
    TOOLS_ROOT,
    Triple,
    argh,
    chdir,
    cmd,
    run_main,
)
from impl.presubmit import Check, CheckContext, run_checks, Group

python = cmd("python3")
mypy = cmd("mypy").with_color_env("MYPY_FORCE_COLOR")
black = cmd("black").with_color_arg(always="--color", never="--no-color")
mdformat = cmd("mdformat")

# Only aarch64 is supported on Asahi Fedora Remix.
Platform = Literal["aarch64"]
PLATFORMS: Tuple[Platform, ...] = typing.get_args(Platform)


def platform_is_supported(platform: Platform):
    "Returns true if the platform is available as a target in rustup."
    triple = Triple.from_shorthand(platform)
    installed_toolchains = cmd("rustup target list --installed").lines()
    return str(triple) in installed_toolchains


####################################################################################################
# Check methods


def check_python_tests(_: CheckContext):
    "Runs unit tests for python dev tooling."
    PYTHON_TESTS = [
        "impl.common",
    ]
    return [python.with_cwd(TOOLS_ROOT).with_args("-m", file) for file in PYTHON_TESTS]


def check_python_types(context: CheckContext):
    "Run mypy type checks on python dev tooling."
    return [mypy("--pretty", file) for file in context.all_files]


def check_python_format(context: CheckContext):
    "Runs the black formatter on python dev tooling."
    return black.with_args(
        "--check" if not context.fix else None,
        *context.modified_files,
    )


def check_markdown_format(context: CheckContext):
    "Runs mdformat on all markdown files."
    if "blaze" in mdformat("--version").stdout():
        raise Exception(
            "You are using google's mdformat. "
            + "Please update your PATH to ensure the pip installed mdformat is available."
        )
    return mdformat.with_args(
        "--wrap 100",
        "--check" if not context.fix else "",
        *context.modified_files,
    )


def check_rust_format(context: CheckContext):
    "Runs rustfmt on all modified files."
    rustfmt = cmd(cmd("rustup +nightly which rustfmt").stdout())
    return rustfmt.with_args(
        "--edition=2021",
        "--check" if not context.fix else None,
        *context.modified_files,
    )


def check_cargo_toml_formatting(context: CheckContext):
    "Runs cargo-sort on modified Cargo.toml files."
    return cmd("cargo-sort").with_args(
        "--check" if not context.fix else None,
        *[f.parent for f in context.modified_files],
    )


def check_clippy(context: CheckContext, platform: Platform = "aarch64"):
    "Runs clippy on all crates for aarch64."
    triple = Triple.from_shorthand(platform)
    if not platform_is_supported(platform):
        print(f"Skipping clippy for {platform}: target not installed.")
        return None
    return (
        cmd("cargo clippy")
        .with_args(
            "--workspace",
            f"--target={triple}",
            "--",
            "-D", "warnings",
        )
        .with_envs(triple.get_cargo_env())
    )


def check_build(context: CheckContext, platform: Platform = "aarch64"):
    "Runs cargo build for aarch64."
    triple = Triple.from_shorthand(platform)
    if not platform_is_supported(platform):
        print(f"Skipping build for {platform}: target not installed.")
        return None
    return (
        cmd("cargo build")
        .with_args("--workspace", f"--target={triple}")
        .with_envs(triple.get_cargo_env())
    )


####################################################################################################
# Check registry

CHECKS: List[Check] = [
    Check(
        check_python_tests,
        python_tools=True,
        groups=["python"],
    ),
    Check(
        check_python_types,
        python_tools=True,
        files=["**/*.py"],
        groups=["python"],
    ),
    Check(
        check_python_format,
        python_tools=True,
        files=["**/*.py"],
        can_fix=True,
        groups=["python", "format"],
    ),
    Check(
        check_markdown_format,
        python_tools=True,
        files=["**/*.md"],
        can_fix=True,
        groups=["format"],
    ),
    Check(
        check_rust_format,
        files=["**/*.rs"],
        can_fix=True,
        groups=["format"],
    ),
    Check(
        check_clippy,
        files=["**/*.rs", "**/Cargo.toml"],
        groups=["rust"],
        priority=True,
    ),
    Check(
        check_build,
        files=["**/*.rs", "**/Cargo.toml"],
        groups=["rust"],
        priority=True,
    ),
]

GROUPS: List[Group] = [
    Group("all", "Run all checks", [c.name for c in CHECKS]),
    Group("python", "Run python checks", ["python_tests", "python_types", "python_format"]),
    Group("format", "Run all formatters", ["python_format", "markdown_format", "rust_format"]),
    Group("rust", "Run rust checks", ["clippy", "build"]),
]


def main(
    fix: bool = False,
    list_checks: bool = False,
    group: Optional[str] = "all",
    checks: Optional[List[str]] = None,
):
    chdir(CROSVM_ROOT)
    run_checks(CHECKS, GROUPS, fix=fix, list_checks=list_checks, group=group, checks=checks)


run_main(main, usage="./tools/presubmit [OPTIONS]")
