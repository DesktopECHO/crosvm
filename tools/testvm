# Manages the aarch64 test VM on Asahi Fedora Remix.
# x86_64 support removed — only aarch64 is available.
# Use ./tools/aarch64vm as a convenience wrapper.

import shutil
from typing import Iterable, Optional

from impl.common import run_commands, argh, console, strip_ansi_escape_sequences
from impl import testvm
from impl.testvm import Arch, VmState

USAGE = """Manages the aarch64 test VM for crosvm on Asahi Fedora Remix.

The easiest way to use the VM is:
  $ ./tools/aarch64vm ssh

This will initialize and boot the VM, wait for SSH to become available,
and open an SSH session. The VM stays alive between calls.

Available commands:
  up     Start the VM if it is not already running.
  stop   Gracefully stop the VM.
  kill   Send SIGKILL to the VM.
  clean  Stop the VM and delete all images.
  logs   Print the VM console log.
  ssh    Open an interactive SSH session (starts VM if needed).
"""

# Only aarch64 is supported on Asahi Fedora Remix.
ARCHS = testvm.ARCH_OPTIONS  # ("aarch64",)


def cli_shorthand(arch: Arch):
    return "tools/aarch64vm"


@argh.arg("--arch", default="aarch64", choices=ARCHS)
def up(arch: Arch = "aarch64", reset: bool = False, wait: bool = False, timeout: int = 120):
    "Start the aarch64 VM if it's not already running."
    testvm.up(arch, reset, wait, timeout)


@argh.arg("--arch", default="aarch64", choices=ARCHS)
def run(arch: Arch = "aarch64", reset: bool = False):
    "Run the VM in foreground for debugging purposes."
    if testvm.is_running(arch):
        raise Exception("VM is already running")
    testvm.build_if_needed(arch, reset)
    testvm.run_qemu(
        arch,
        testvm.rootfs_img_path(arch),
        background=False,
    )


@argh.arg("--arch", default="aarch64", choices=ARCHS)
def shell(arch: Arch = "aarch64", timeout: int = 120):
    "Start an interactive SSH session; starts the VM if needed."
    testvm.up(arch, wait=True, timeout=timeout)
    testvm.ssh_exec(arch)


@argh.arg("--arch", default="aarch64", choices=ARCHS)
def stop(arch: Arch = "aarch64"):
    "Gracefully stop the running VM."
    if not testvm.is_running(arch):
        print(f"{arch} VM is not running")
        return
    console.print(f"Stopping {arch} VM")
    testvm.ssh_exec(arch, "sudo poweroff")


@argh.arg("--arch", default="aarch64", choices=ARCHS)
def kill(arch: Arch = "aarch64"):
    "Kill the running VM with SIGKILL."
    if not testvm.is_running(arch):
        console.print(f"{arch} VM is not running")
        return
    console.print(f"Killing {arch} VM process")
    testvm.kill_vm(arch)
    print()


@argh.arg("--arch", default="aarch64", choices=ARCHS)
def clean(arch: Arch = "aarch64"):
    "Stop the VM and delete all data."
    if testvm.is_running(arch):
        kill(arch)
    if testvm.data_dir(arch).exists():
        console.print("Cleaning data directory", testvm.data_dir(arch))
        shutil.rmtree(testvm.data_dir(arch))
    print()


@argh.arg("--arch", default="aarch64", choices=ARCHS)
def logs(arch: Arch = "aarch64"):
    "Print the VM console log."
    log = testvm.log_path(arch)
    if log.exists():
        print(log.read_text())
    else:
        print(f"No log found at {log}")


def status():
    "Show the current state of the aarch64 test VM."
    arch: Arch = "aarch64"
    state = testvm.state(arch)
    ssh_port = testvm.ssh_port_path(arch)
    port_str = ssh_port.read_text().strip() if ssh_port.exists() else "unknown"

    if state == VmState.REACHABLE:
        console.print(f"[green]aarch64 VM is running[/green] (SSH port: {port_str})")
        console.print(f"  Connect: [bold]./tools/aarch64vm ssh[/bold]")
    elif state == VmState.RUNNING:
        console.print(f"[yellow]aarch64 VM is starting...[/yellow] (SSH port: {port_str})")
    else:
        console.print("[red]aarch64 VM is not running[/red]")
        console.print(f"  Start:   [bold]./tools/aarch64vm up --wait[/bold]")


run_commands(up, run, shell, stop, kill, clean, logs, status)
